# ── Supabase ───────────────────────────────────────────────────────
# Supabase に接続する場合は URL と Anon Key を設定してください。
# 未設定の場合は SQLite にフォールバックします。
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── LLM (LiteLLM) ──────────────────────────────────────────────────
# OpenAI の場合:
#   LITELLM_MODEL=gpt-4o-mini
#   LITELLM_API_BASE=          (空でOK)
#   OPENAI_API_KEY=sk-...
#
# Ollama (ローカル) の場合:
#   LITELLM_MODEL=ollama/qwen2.5-coder:7b
#   LITELLM_API_BASE=http://localhost:11434

LITELLM_MODEL=ollama/qwen2.5-coder:7b
LITELLM_API_BASE=http://localhost:11434

# OpenAI API キー (OpenAI モデルを使う場合のみ)
OPENAI_API_KEY=
