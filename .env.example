# ── LLM (LiteLLM) ──────────────────────────────────────────────────
# OpenAI の場合:
#   LITELLM_MODEL=gpt-4o-mini
#   LITELLM_API_BASE=          (空でOK)
#   OPENAI_API_KEY=sk-...
#
# Ollama (ローカル) の場合:
#   LITELLM_MODEL=ollama/qwen2.5-coder:7b
#   LITELLM_API_BASE=http://localhost:11434

LITELLM_MODEL=ollama/qwen2.5-coder:7b
LITELLM_API_BASE=http://localhost:11434

# OpenAI API キー (OpenAI モデルを使う場合のみ)
OPENAI_API_KEY=

# ── LINE / その他の接続情報 ────────────────────────────────────────
# LINE の認証情報はアプリ内の Settings 画面から設定します。
# DB (SQLite) は自動的に ~/.lifescript/lifescript.db に作成されます。
