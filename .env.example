# ── Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# ── LLM (LiteLLM) ──────────────────────────────────────────────────
# 開発中 (Google AI Studio 無料枠)
LIFESCRIPT_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=your_gemini_key

# ハッカソン当日 (GCP $300クレジット)
# LIFESCRIPT_MODEL=gemini/gemini-2.5-pro

# Ollama (ローカル) の場合:
# LIFESCRIPT_MODEL=ollama/qwen2.5-coder:7b
# LITELLM_API_BASE=http://localhost:11434

# ── API Server ──────────────────────────────────────────────────────
API_PORT=8000
