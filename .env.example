# ── Supabase ───────────────────────────────────────────────────────
# アプリ固定の URL と Anon Key（ユーザーはメール+パスワードでログイン）
# Supabase Dashboard → Settings → API から取得
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# ── LLM (LiteLLM) ──────────────────────────────────────────────────
# OpenAI の場合:
#   LITELLM_MODEL=gpt-4o-mini
#   LITELLM_API_BASE=          (空でOK)
#   OPENAI_API_KEY=sk-...
#
# Ollama (ローカル) の場合:
#   LITELLM_MODEL=ollama/qwen2.5-coder:7b
#   LITELLM_API_BASE=http://localhost:11434

LITELLM_MODEL=ollama/qwen2.5-coder:7b
LITELLM_API_BASE=http://localhost:11434

# OpenAI API キー (OpenAI モデルを使う場合のみ)
OPENAI_API_KEY=
